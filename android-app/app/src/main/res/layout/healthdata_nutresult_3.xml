<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/default_action_bar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#C2F189"
        android:gravity="center"
        android:text="fit-fresh"
        android:textSize="30dp"
        android:textStyle="bold"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="-2dp" />

    <Button
        android:id="@+id/button2"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/search"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.934"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/default_returnbutton"
        android:layout_width="55dp"
        android:layout_height="52dp"
        android:layout_marginStart="8dp"
        android:background="#63AC0F"
        android:foreground="@drawable/returnbutton"
        app:layout_constraintBottom_toBottomOf="@+id/default_action_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="30dp"
        android:text="메인화면"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="90dp"></LinearLayout>
        <!-- 탄수화물 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="322dp"
                android:layout_height="31dp"
                android:layout_marginLeft="20dp"
                android:text="탄수화물이 부족할때 도움을 주는 음식"
                android:textColor="#101010"
                android:textSize="20dp"></TextView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <Button
                    android:id="@+id/bread"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/list_bread"
                    tools:layout_editor_absoluteX="29dp"
                    tools:layout_editor_absoluteY="143dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="9dp">

                </View>

                <Button
                    android:id="@+id/rice"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/list_rice"
                    tools:layout_editor_absoluteX="29dp"
                    tools:layout_editor_absoluteY="143dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="10dp">

                </View>

                <Button
                    android:id="@+id/sp"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/list_sweetpotato"
                    tools:layout_editor_absoluteX="29dp"
                    tools:layout_editor_absoluteY="143dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="27dp"
                    android:gravity="center"
                    android:text="빵"
                    android:textSize="15dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="9dp"></View>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="27dp"
                    android:gravity="center"
                    android:text="잡곡류"
                    android:textSize="15dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="9dp"></View>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="27dp"
                    android:gravity="center"
                    android:text="고구마"
                    android:textSize="15dp" />


            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp">

        </View>
        <!-- 단백질 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="322dp"
                android:layout_height="31dp"
                android:layout_marginLeft="20dp"
                android:text="단백질이 부족할때 도움을 주는 음식"
                android:textColor="#101010"
                android:textSize="20dp"></TextView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <Button
                    android:id="@+id/meat"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/list_meat"
                    tools:layout_editor_absoluteX="29dp"
                    tools:layout_editor_absoluteY="143dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="10dp">

                </View>

                <Button
                    android:id="@+id/fish"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/list_fish"
                    tools:layout_editor_absoluteX="29dp"
                    tools:layout_editor_absoluteY="143dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="10dp">

                </View>

                <Button
                    android:id="@+id/bam"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/list_bam"
                    tools:layout_editor_absoluteX="29dp"
                    tools:layout_editor_absoluteY="143dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="27dp"
                    android:gravity="center"
                    android:text="육류"
                    android:textSize="15dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="9dp"></View>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="27dp"
                    android:gravity="center"
                    android:text="생선"
                    android:textSize="15dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="9dp"></View>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="27dp"
                    android:gravity="center"
                    android:text="밤"
                    android:textSize="15dp" />


            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp">

        </View>
        <!-- 지방 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="322dp"
                android:layout_height="31dp"
                android:layout_marginLeft="20dp"
                android:text="지방이 부족할때 도움을 주는 음식"
                android:textColor="#101010"
                android:textSize="20dp"></TextView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <Button
                    android:id="@+id/milk"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/list_milk"
                    tools:layout_editor_absoluteX="29dp"
                    tools:layout_editor_absoluteY="143dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="10dp">

                </View>

                <Button
                    android:id="@+id/nut"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/list_nut"
                    tools:layout_editor_absoluteX="29dp"
                    tools:layout_editor_absoluteY="143dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="10dp">

                </View>

                <Button
                    android:id="@+id/salmon"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/list_salmon"
                    tools:layout_editor_absoluteX="29dp"
                    tools:layout_editor_absoluteY="143dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="27dp"
                    android:gravity="center"
                    android:text="유제품"
                    android:textSize="15dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="9dp"></View>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="27dp"
                    android:gravity="center"
                    android:text="견과류"
                    android:textSize="15dp" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="9dp"></View>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="27dp"
                    android:gravity="center"
                    android:text="연어"
                    android:textSize="15dp" />


            </LinearLayout>
        </LinearLayout>


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
