<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/default_action_bar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#C2F189"
        android:gravity="center"
        android:text="fit-fresh"
        android:textSize="25dp"
        android:textStyle="bold"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="-2dp" />

    <Button
        android:id="@+id/button2"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/search"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.934"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/default_returnbutton"
        android:layout_width="55dp"
        android:layout_height="52dp"
        android:layout_marginStart="8dp"
        android:background="#63AC0F"
        android:foreground="@drawable/returnbutton"
        app:layout_constraintBottom_toBottomOf="@+id/default_action_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/retun_to_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="메인페이지"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginRight="30dp" />


    <!-- linearlayout-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:ignore="MissingConstraints">
        <!-- actionbar 공백 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal">
        </LinearLayout>
        <!--##님은 ### 점수가 가장 높네요! -->
        <!-- 1.## : 사용자 이름-->
        <!-- 2.### : 의심증상 이름-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tv_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="##님은 ###점수가 가장 높네요"
                android:textSize="25dp" />

        </LinearLayout>
        <!-- 사용자 아이디와 그래프 사이 공백 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="10dp">
        </LinearLayout>
        <!-- 그래프 및 전체대비 비율-->
        <LinearLayout

            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.github.mikephil.charting.charts.PieChart
                android:id = "@+id/pie_chart"
                android:layout_width="250dp"
                android:layout_height="250dp">

            </com.github.mikephil.charting.charts.PieChart>



            <!-- 추가 설명 -->
            <!-- 아니 개씨벌 여기서 뭘 어캐 적으라는지 모르겟어-->
            <!-- 미친놈들인가 왜 갑자기 연령대가 나오는지 모르겟다-->
            <!-- 그래서 일단 비워놓음-->
            <TextView
                android:id="@+id/tv_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="###님이 속한 연령대는 전체 대비 23% 정도에요!"
                android:textSize="25dp" />

        </LinearLayout>
        <!-- 질병의 원인-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_bac"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:text="###의 원인입니다"
                android:textSize="25dp" />

            <TextView
                android:id="@+id/reason_a"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:text="-A"
                android:textSize="20dp" />

            <TextView
                android:id="@+id/reason_b"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:text="-B"
                android:textSize="20dp" />

            <TextView
                android:id="@+id/reason_c"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:text="-C"
                android:textSize="20dp" />

        </LinearLayout>
        <!-- 공백 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="10dp">

        </LinearLayout>
        <!-- 질병의 증상-->
        <!-- 질환 예방에 좋은 음식 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_food"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:text="### 예방에 좋은 음식은?"
                android:textSize="25dp" />
            <!-- 질환 예방에 좋은 음식, 버튼-->
            <!-- 이거 텍뷰랑 버튼 두개 할건지-->
            <!-- 텍뷰 안만들고 버튼에 이름 넣어서 끝할건지 정해주세요-->
            <!-- 일단은 몰라서 텍뷰도 만들어봅니다-->


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/suggest1"
                    android:text = "추천음식1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="30dp">

                </Button>
                <Button
                    android:id="@+id/suggest2"
                    android:text = "추천음식2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="30dp">

                </Button>
                <Button
                    android:id="@+id/suggest3"
                    android:text = "추천음식3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="30dp">

                </Button>

            </LinearLayout>

        </LinearLayout>



    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>